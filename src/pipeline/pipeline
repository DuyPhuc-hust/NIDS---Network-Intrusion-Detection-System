from src.data.loader import load_cicids
from src.data.preprocess import clean_data, split_xy, encode_features, scale_features
from src.models.train import train_model

def run_train_pipeline(data_path, sample_size=None):
    print("[+] Starting pipeline...")

    df = load_cicids(data_path, sample_size)

    df = clean_data(df)

    X, y = split_xy(df, "Label")

    X = encode_features(X)

    feature_columns = X.columns.tolist()

    X_scaled, scaler = scale_features(X)

    model = train_model(X_scaled, y)

    return model, scaler, feature_columns